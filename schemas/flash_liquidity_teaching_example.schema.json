{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://architectofathena.github.io/CodexTradingEngine/schemas/flash_liquidity_teaching_example.schema.json",
  "title": "Flash Liquidity Teaching Example",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "route_candidate_id", "providers", "amount_buckets", "note", "authority"],
  "properties": {
    "schema_version": {"const": "flash-liquidity-teaching-example-v0.1"},
    "route_candidate_id": {"type": "string", "pattern": "^triangle:"},
    "providers": {"type": "array", "minItems": 1},
    "amount_buckets": {"type": "array", "minItems": 1},
    "note": {"type": "string", "minLength": 1},
    "authority": {"const": false}
  }
}
