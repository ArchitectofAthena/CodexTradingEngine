{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spiralbloom.local/schemas/evidence_bundle_v0_1.schema.json",
  "title": "EVE_Q++ EvidenceBundle v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "contract_version",
    "artifact_id",
    "created_at",
    "producer",
    "proposal_artifact_sha256",
    "sources",
    "contradictions",
    "evidence_grounding",
    "evidence_state",
    "agreement_is_not_truth",
    "authority",
    "human_promotion_required"
  ],
  "properties": {
    "artifact_type": {"const": "EvidenceBundle"},
    "contract_version": {"const": "eve_q_cross_repo_v0.1"},
    "artifact_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "component", "commit_sha"],
      "properties": {
        "repository": {"enum": ["ArchitectofAthena/CodexTradingEngine", "ArchitectofAthena/spiralbloom-os"]},
        "component": {"type": "string", "minLength": 1},
        "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "proposal_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_uri", "source_kind", "independence_group", "content_sha256", "position", "causal_support"],
        "properties": {
          "source_id": {"type": "string", "minLength": 1},
          "source_uri": {"type": "string", "minLength": 1},
          "source_kind": {"enum": ["market_data", "onchain_data", "simulation_receipt", "policy", "impact_receipt", "independent_analysis", "counterevidence"]},
          "independence_group": {"type": "string", "minLength": 1},
          "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "position": {"enum": ["support", "oppose", "mixed", "uncertain"]},
          "causal_support": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contradiction_id", "status", "summary", "source_sha256"],
        "properties": {
          "contradiction_id": {"type": "string", "minLength": 1},
          "status": {"enum": ["new", "reviewed", "resolved", "unresolved"]},
          "summary": {"type": "string", "minLength": 1},
          "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "evidence_grounding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_independence",
        "provenance_diversity",
        "contradiction_coverage",
        "causal_support",
        "redundancy_penalty",
        "coalition_coherence",
        "coherence_conflict"
      ],
      "properties": {
        "source_independence": {"type": "number", "minimum": 0, "maximum": 1},
        "provenance_diversity": {"type": "number", "minimum": 0, "maximum": 1},
        "contradiction_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "causal_support": {"type": "number", "minimum": 0, "maximum": 1},
        "redundancy_penalty": {"type": "number", "minimum": 0, "maximum": 1},
        "coalition_coherence": {"type": "number", "minimum": 0, "maximum": 1},
        "coherence_conflict": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "evidence_state": {"enum": ["GROUNDED", "HERDING_RISK", "INTEGRATING", "INSUFFICIENT"]},
    "agreement_is_not_truth": {"const": true},
    "authority": {"const": false},
    "human_promotion_required": {"type": "boolean"}
  }
}
