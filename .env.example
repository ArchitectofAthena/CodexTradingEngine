# EVE_Q SlurperBot v2 - Environment Configuration
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git!

# ========================================
# EXECUTION MODE
# ========================================
SIMULATION_MODE=true              # Set to false for live trading (DANGEROUS!)
DRY_RUN=true                      # Additional safety layer

# ========================================
# BLOCKCHAIN RPC ENDPOINTS
# ========================================
# Get free RPC endpoints from:
# - Alchemy: https://www.alchemy.com/
# - Infura: https://infura.io/
# - QuickNode: https://www.quicknode.com/

ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# ========================================
# WALLET CONFIGURATION
# ========================================
# CRITICAL: Use a dedicated wallet for bot operations
# NEVER use your main wallet!
# NEVER commit your private key to git!

PRIVATE_KEY=                      # Leave empty for simulation mode
                                  # For live mode: 0x... (64 hex characters)

# ========================================
# IPFS CONFIGURATION
# ========================================
# Get IPFS pinning service from:
# - Pinata: https://www.pinata.cloud/
# - Infura IPFS: https://infura.io/product/ipfs
# - NFT.Storage: https://nft.storage/

IPFS_PROVIDER=pinata              # Options: pinata, infura, nft_storage
IPFS_API_KEY=                     # Your IPFS service API key
IPFS_API_SECRET=                  # Your IPFS service API secret
IPFS_GATEWAY=https://gateway.pinata.cloud

# ========================================
# CHARITY WALLET ADDRESSES
# ========================================
# Verify these are legitimate charity addresses!
# Default addresses are placeholders - REPLACE WITH REAL ONES

CHARITY_GIVEDIRECTLY_ADDRESS=0x750EF1D7a0b4Ab1c97B7A623D7917CcEb5ea779C
CHARITY_HUNGERPROJECT_ADDRESS=0x0000000000000000000000000000000000000001
CHARITY_WATER_ADDRESS=0x0000000000000000000000000000000000000002

# ========================================
# SAFETY LIMITS
# ========================================
MAX_GAS_PRICE_GWEI=100            # Abort if gas > this
MIN_PROFIT_ETH=0.001              # Minimum profit to execute
MAX_SLIPPAGE_PERCENT=1.0          # Maximum acceptable slippage
MIN_ETH_BALANCE=0.1               # Minimum account balance

# ========================================
# GRACE-BASED ECONOMICS
# ========================================
BASELINE_TTL_HOURS=24             # Default autonomy window
MAX_TTL_HOURS=48                  # Maximum earned autonomy
CHARITY_PERCENTAGE=0.15           # 15% - IMMUTABLE
CONSECUTIVE_FAILURE_THRESHOLD=5   # Grace decay threshold

# ========================================
# MONITORING & ALERTS
# ========================================
ENABLE_PROMETHEUS=false           # Enable Prometheus metrics export
PROMETHEUS_PORT=9090

ENABLE_DISCORD_ALERTS=false       # Send alerts to Discord
DISCORD_WEBHOOK_URL=

ENABLE_EMAIL_ALERTS=false         # Send alerts via email
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO                    # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_DIR=logs
METRICS_DIR=data/metrics

# ========================================
# DEVELOPMENT/TESTING
# ========================================
ENABLE_TESTNET=false              # Use testnets instead of mainnet
TESTNET_RPC_URL=https://goerli.infura.io/v3/YOUR_API_KEY_HERE
